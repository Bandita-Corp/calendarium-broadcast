// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String?
  role           Role     @default(USER)
  refreshToken   String?
  periods        Period[]
  presets        Preset[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("users")
}

model Period {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  color     String   @default("#FFD700")
  createdBy User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  preset    Preset?  @relation(fields: [presetId], references: [id], onDelete: SetNull)
  presetId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("periods")
}

model Preset {
  id        String   @id @default(uuid())
  name      String
  createdBy User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  periods   Period[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("presets")
}
